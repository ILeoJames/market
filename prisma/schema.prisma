generator client {
  provider = "prisma-client"
  output   = "../prisma/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  USER
  SUPPORT
  MODERATOR
  ARBITRATOR
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  IN_PROGRESS
  COMPLETED
  DISPUTED
  CANCELLED
  REFUNDED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum NotificationType {
  ORDER_CREATED
  ORDER_PAID
  ORDER_CONFIRMED
  ORDER_CANCELLED
  NEW_MESSAGE
  DISPUTE_OPENED
  DISPUTE_UPDATED
  PAYMENT_RECEIVED
  WITHDRAWAL_REQUESTED
  WITHDRAWAL_PROCESSED
  TICKET_REPLY
  LISTING_PUBLISHED
  LISTING_BLOCKED
  WARNING_ISSUED
}

enum DeliveryType {
  AUTOMATIC
  MANUAL
}

enum Currency {
  RUB
  USD
  KZT
}

enum Language {
  RU
  EN
}

// ============================================
// CORE MODELS
// ============================================

model User {
  id                    String    @id @default(cuid())
  login                 String    @unique @db.VarChar(50)
  email                 String    @unique @db.VarChar(255)
  password              String    @db.Text
  avatar                String?   @db.Text
  role                  UserRole  @default(USER)
  isOnline              Boolean   @default(false)
  lastSeen              DateTime?
  emailVerified         Boolean   @default(false)
  currency              Currency  @default(RUB)
  language              Language  @default(RU)
  balance               Decimal   @default(0) @db.Decimal(10, 2)
  rating                Decimal   @default(0) @db.Decimal(3, 2)
  totalSales            Int       @default(0)
  totalOrders           Int       @default(0)
  successfulDeals       Int       @default(0)
  disputesCount         Int       @default(0)
  warningsCount         Int       @default(0)
  isBlocked             Boolean   @default(false)
  blockedAt             DateTime?
  blockReason           String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  listings              Listing[]
  orders                Order[] @relation("BuyerOrders")
  sales                 Order[] @relation("SellerOrders")
  reviews               Review[] @relation("ReceivedReviews")
  givenReviews          Review[] @relation("GivenReviews")
  messages              Message[]
  notifications         Notification[]
  tickets               Ticket[]
  ticketMessages        TicketMessage[]
  disputes              Dispute[] @relation("DisputeCreator")
  disputeResponses      DisputeResponse[]
  wallet                Wallet?
  withdrawals           Withdrawal[]
  financialTransactions FinancialTransaction[]
  listingBoosts         ListingBoost[]
  warnings              UserWarning[]
  receivedWarnings      UserWarning[] @relation("WarnedUser")
  favoriteListings      FavoriteListing[]
  cartItems             CartItem[]

  sessions              Session[]
  accounts              Account[]

  @@index([login])
  @@index([email])
  @@index([role])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String    @db.Text
  providerId            String    @db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String   @db.Text
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// ============================================
// MARKETPLACE MODELS
// ============================================

// Categories
model Category {
  id          String    @id @default(cuid())
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?   @db.Text
  icon        String?   @db.Text
  parentId    String?
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  subcategories Category[] @relation("CategoryHierarchy")
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  commission  Decimal   @default(5) @db.Decimal(5, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  listings    Listing[]

  @@index([slug])
  @@index([parentId])
  @@map("categories")
}

// Listings
model Listing {
  id          String      @id @default(cuid())
  title       String      @db.VarChar(255)
  description String      @db.Text
  price       Decimal     @db.Decimal(10, 2)
  currency    Currency    @default(RUB)
  deliveryType DeliveryType
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sellerId    String
  seller      User        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  images      ListingImage[]
  automaticData AutomaticDeliveryData?
  status      ListingStatus @default(DRAFT)
  views       Int         @default(0)
  favoritesCount Int      @default(0)
  isBoosted   Boolean     @default(false)
  boostedAt   DateTime?
  lastBoostedAt DateTime?
  publishedAt DateTime?
  rejectedAt  DateTime?
  rejectionReason String? @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orders      OrderItem[]
  reviews     Review[]
  boosts      ListingBoost[]
  history     ListingHistory[]
  favorites   FavoriteListing[]

  @@index([categoryId])
  @@index([sellerId])
  @@index([status])
  @@index([isBoosted])
  @@index([publishedAt])
  @@map("listings")
}

enum ListingStatus {
  DRAFT
  PENDING
  ACTIVE
  SOLD
  HIDDEN
  BLOCKED
  REJECTED
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([listingId])
  @@map("listing_images")
}

model AutomaticDeliveryData {
  id        String   @id @default(cuid())
  listingId String   @unique
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  data      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
  @@map("automatic_delivery_data")
}

model ListingHistory {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  action      String   @db.VarChar(50)
  oldPrice    Decimal? @db.Decimal(10, 2)
  newPrice    Decimal? @db.Decimal(10, 2)
  oldDesc     String?  @db.Text
  newDesc     String?  @db.Text
  changedBy   String?
  createdAt   DateTime @default(now())

  @@index([listingId])
  @@map("listing_history")
}

model ListingBoost {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  boostedAt DateTime @default(now())
  nextBoostAvailable DateTime

  @@index([listingId])
  @@index([userId])
  @@index([categoryId])
  @@map("listing_boosts")
}

// Orders
model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique @db.VarChar(20)
  buyerId     String
  buyer       User        @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Restrict)
  sellerId    String
  seller      User        @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Restrict)
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(10, 2)
  platformFee Decimal     @db.Decimal(10, 2)
  sellerAmount Decimal    @db.Decimal(10, 2)
  items       OrderItem[]
  chat        Chat?
  dispute     Dispute?
  paidAt      DateTime?
  completedAt DateTime?
  cancelledAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([orderNumber])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Restrict)
  quantity  Int      @default(1)
  price     Decimal  @db.Decimal(10, 2)
  platformFee Decimal @db.Decimal(10, 2)
  sellerAmount Decimal @db.Decimal(10, 2)
  delivered Boolean   @default(false)
  deliveredAt DateTime?
  autoDelivered Boolean @default(false)
  deliveredData String? @db.Text

  @@index([orderId])
  @@index([listingId])
  @@map("order_items")
}

// Chat
model Chat {
  id        String    @id @default(cuid())
  orderId   String?   @unique
  order     Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketId  String?   @unique
  ticket    Ticket?   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  messages  Message[]
  participants ChatParticipant[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([orderId])
  @@index([ticketId])
  @@map("chats")
}

model ChatParticipant {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isArbitrator Boolean @default(false)
  joinedAt  DateTime @default(now())
  leftAt    DateTime?

  @@unique([chatId, userId])
  @@index([chatId])
  @@index([userId])
  @@map("chat_participants")
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  isRead    Boolean  @default(false)
  readAt    DateTime?
  attachments MessageAttachment[]
  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([senderId])
  @@index([isRead])
  @@map("messages")
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url       String   @db.Text
  fileName  String   @db.VarChar(255)
  fileSize  Int?
  fileType  String?  @db.VarChar(50)
  createdAt DateTime @default(now())

  @@index([messageId])
  @@map("message_attachments")
}

// Reviews
model Review {
  id          String   @id @default(cuid())
  orderId     String   @unique
  reviewerId  String
  reviewer    User     @relation("GivenReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewedId  String
  reviewed    User     @relation("ReceivedReviews", fields: [reviewedId], references: [id], onDelete: Cascade)
  listingId   String?
  listing     Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  rating      Int      @db.Int
  comment     String?  @db.Text
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([reviewedId])
  @@index([reviewerId])
  @@index([listingId])
  @@map("reviews")
}

// Disputes
model Dispute {
  id          String        @id @default(cuid())
  orderId     String        @unique
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  openedById  String
  openedBy    User          @relation("DisputeCreator", fields: [openedById], references: [id], onDelete: Restrict)
  status      DisputeStatus @default(OPEN)
  reason      String        @db.Text
  resolution  String?       @db.Text
  resolvedInFavorOf String? @db.VarChar(20)
  refundAmount Decimal?     @db.Decimal(10, 2)
  assignedTo  String?
  openedAt    DateTime      @default(now())
  resolvedAt  DateTime?
  responses   DisputeResponse[]

  @@index([orderId])
  @@index([status])
  @@map("disputes")
}

model DisputeResponse {
  id        String   @id @default(cuid())
  disputeId String
  dispute   Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  attachments DisputeAttachment[]
  createdAt DateTime @default(now())

  @@index([disputeId])
  @@index([userId])
  @@map("dispute_responses")
}

model DisputeAttachment {
  id           String   @id @default(cuid())
  responseId   String
  response     DisputeResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  url          String   @db.Text
  fileName     String   @db.VarChar(255)
  fileSize     Int?
  fileType     String?  @db.VarChar(50)
  createdAt    DateTime @default(now())

  @@index([responseId])
  @@map("dispute_attachments")
}

// Tickets (Support)
model Ticket {
  id          String      @id @default(cuid())
  ticketNumber String     @unique @db.VarChar(20)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String      @db.VarChar(255)
  category    String      @db.VarChar(100)
  status      TicketStatus @default(OPEN)
  priority    String      @default("normal") @db.VarChar(20)
  assignedTo  String?
  chat        Chat?
  messages    TicketMessage[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  closedAt    DateTime?

  @@index([ticketNumber])
  @@index([userId])
  @@index([status])
  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  attachments String? @db.Text
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([userId])
  @@map("ticket_messages")
}

// Finance
model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  pendingBalance Decimal @default(0) @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("wallets")
}

model FinancialTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   @db.VarChar(50)
  amount      Decimal  @db.Decimal(10, 2)
  balanceBefore Decimal @db.Decimal(10, 2)
  balanceAfter Decimal @db.Decimal(10, 2)
  description String   @db.Text
  referenceId String?  @db.VarChar(100)
  status      String   @default("completed") @db.VarChar(20)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([referenceId])
  @@map("financial_transactions")
}

model Withdrawal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(10, 2)
  method      String   @db.VarChar(50)
  details     String   @db.Text
  status      String   @default("pending") @db.VarChar(20)
  processedBy String?
  processedAt DateTime?
  rejectedReason String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("withdrawals")
}

// Cart & Favorites
model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, listingId])
  @@index([userId])
  @@map("cart_items")
}

model FavoriteListing {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("favorite_listings")
}

// Notifications
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String           @db.Text
  isRead    Boolean          @default(false)
  link      String?          @db.Text
  metadata  String?          @db.Text
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@map("notifications")
}

// Warnings & Logs
model UserWarning {
  id          String   @id @default(cuid())
  userId      String
  warnedUser  User     @relation("WarnedUser", fields: [userId], references: [id], onDelete: Cascade)
  issuedBy    String
  issuer      User     @relation(fields: [issuedBy], references: [id], onDelete: SetNull)
  reason      String   @db.Text
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("user_warnings")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   @db.VarChar(100)
  entityType String? @db.VarChar(50)
  entityId  String?  @db.VarChar(100)
  oldValue  String?  @db.Text
  newValue  String?  @db.Text
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

// Settings
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  type      String   @default("string") @db.VarChar(20)
  updatedAt DateTime @updatedAt

  @@index([key])
  @@map("site_settings")
}
